t.keys(styleAttributes)) {\n","    element.style[key] = styleAttributes[key];\n","  }\n","  return element;\n","}\n","\n","// Max number of bytes which will be uploaded at a time.\n","const MAX_PAYLOAD_SIZE = 100 * 1024;\n","\n","function _uploadFiles(inputId, outputId) {\n","  const steps = uploadFilesStep(inputId, outputId);\n","  const outputElement = document.getElementById(outputId);\n","  // Cache steps on the outputElement to make it available for the next call\n","  // to uploadFilesContinue from Python.\n","  outputElement.steps = steps;\n","\n","  return _uploadFilesContinue(outputId);\n","}\n","\n","// This is roughly an async generator (not supported in the browser yet),\n","// where there are multiple asynchronous steps and the Python side is going\n","// to poll for completion of each step.\n","// This uses a Promise to block the python side on completion of each step,\n","// then passes the result of the previous step as the input to the next step.\n","function _uploadFilesContinue(outputId) {\n","  const outputElement = document.getElementById(outputId);\n","  const steps = outputElement.steps;\n","\n","  const next = steps.next(outputElement.lastPromiseValue);\n","  return Promise.resolve(next.value.promise).then((value) => {\n","    // Cache the last promise value to make it available to the next\n","    // step of the generator.\n","    outputElement.lastPromiseValue = value;\n","    return next.value.response;\n","  });\n","}\n","\n","/**\n"," * Generator function which is called between each async step of the upload\n"," * process.\n"," * @param {string} inputId Element ID of the input file picker element.\n"," * @param {string} outputId Element ID of the output display.\n"," * @return {!Iterable<!Object>} Iterable of next steps.\n"," */\n","function* uploadFilesStep(inputId, outputId) {\n","  const inputElement = document.getElementById(inputId);\n","  inputElement.disabled = false;\n","\n","  const outputElement = document.getElementById(outputId);\n","  outputElement.innerHTML = '';\n","\n","  const pickedPromise = new Promise((resolve) => {\n","    inputElement.addEventListener('change', (e) => {\n","      resolve(e.target.files);\n","    });\n","  });\n","\n","  const cancel = document.createElement('button');\n","  inputElement.parentElement.appendChild(cancel);\n","  cancel.textContent = 'Cancel upload';\n","  const cancelPromise = new Promise((resolve) => {\n","    cancel.onclick = () => {\n","      resolve(null);\n","    };\n","  });\n","\n","  // Wait for the user to pick the files.\n","  const files = yield {\n","    promise: Promise.race([pickedPromise, cancelPromise]),\n","    response: {\n","      action: 'starting',\n","    }\n","  };\n","\n","  cancel.remove();\n","\n","  // Disable the input element since further picks are not allowed.\n","  inputElement.disabled = true;\n","\n","  if (!files) {\n","    return {\n","      response: {\n","        action: 'complete',\n","      }\n","    };\n","  }\n","\n","  for (const file of files) {\n","    const li = document.createElement('li');\n","    li.append(span(file.name, {fontWeight: 'bold'}));\n","    li.append(span(\n","        `(${file.type || 'n/a'}) - ${file.size} bytes, ` +\n","        `last modified: ${\n","            file.lastModifiedDate ? file.lastModifiedDate.toLocaleDateString() :\n","                                    'n/a'} - `));\n","    const percent = span('0% done');\n","    li.appendChild(percent);\n","\n","    outputElement.appendChild(li);\n","\n","    const fileDataPromise = new Promise((resolve) => {\n","      const reader = new FileReader();\n","      reader.onload = (e) => {\n","        resolve(e.target.result);\n","      };\n","      reader.readAsArrayBuffer(file);\n","    });\n","    // Wait for the data to be ready.\n","    let fileData = yield {\n","      promise: fileDataPromise,\n","      response: {\n","        action: 'continue',\n","      }\n","    };\n","\n","    // Use a chunked sending to avoid message size limits. See b/62115660.\n","    let position = 0;\n","    do {\n","      const length = Math.min(fileData.byteLength - position, MAX_PAYLOAD_SIZE);\n","      const chunk = new Uint8Array(fileData, position, length);\n","      position += length;\n","\n","      const base64 = btoa(String.fromCharCode.apply(null, chunk));\n","      yield {\n","        response: {\n","          action: 'append',\n","          file: file.name,\n","          data: base64,\n","        },\n","      };\n","\n","      let percentDone = fileData.byteLength === 0 ?\n","          100 :\n","          Math.round((position / fileData.byteLength) * 100);\n","      percent.textContent = `${percentDone}% done`;\n","\n","    } while (position < fileData.byteLength);\n","  }\n","\n","  // All done.\n","  yield {\n","    response: {\n","      action: 'complete',\n","    }\n","  };\n","}\n","\n","scope.google = scope.google || {};\n","scope.google.colab = scope.google.colab || {};\n","scope.google.colab._files = {\n","  _uploadFiles,\n","  _uploadFilesContinue,\n","};\n","})(self);\n","</script> "]},"metadata":{}},{"output_type":"stream","name":"stdout","text":["Saving A_sparse_50x50.mtx to A_sparse_50x50.mtx\n","Saving A_sparse_500x500.mtx to A_sparse_500x500.mtx\n","Saving A_sparse_1000x1000.mtx to A_sparse_1000x1000.mtx\n","Saving b_xtrue_500.npz to b_xtrue_500.npz\n","Saving b_xtrue_1000.npz to b_xtrue_1000.npz\n","Saving A_dense_100x100.npz to A_dense_100x100.npz\n","Saving A_sparse_100x100.mtx to A_sparse_100x100.mtx\n","Saving A_dense_50x50.npz to A_dense_50x50.npz\n"]}],"source":["from google.colab import files\n","uploaded = files.upload()\n"]},{"cell_type":"code","source":["import numpy as np\n","import scipy.sparse as sp\n","from scipy.io import mmread\n","import matplotlib.pyplot as plt\n","import time\n"],"metadata":{"id":"P035r9wGnexl","executionInfo":{"status":"ok","timestamp":1764302482112,"user_tz":-420,"elapsed":222,"user":{"displayName":"Alif Putra Roy","userId":"17840951808929307884"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["def gauss_seidel(A, b, x0=None, tol=1e-8, max_iter=5000, verbose=False):\n","    \"\"\"\n","    Gauss-Seidel solver returning (x, residuals, iters, time_elapsed).\n","    Works for scipy CSR sparse matrices and numpy dense arrays.\n","    Residual sequence: ||A x_k - b||_2\n","    \"\"\"\n","    n = b.shape[0]\n","    if x0 is None:\n","        x = np.zeros(n, dtype=float)\n","    else:\n","        x = x0.astype(float).copy()\n","\n","    residuals = []\n","    start_time = time.time()\n","\n","    if sp.isspmatrix_csr(A):\n","        data = A.data\n","        indices = A.indices\n","        indptr = A.indptr\n","        # extract diagonals (assume diagonal entries present)\n","        diag = np.zeros(n, dtype=float)\n","        for i in range(n):\n","            for idx in range(indptr[i], indptr[i+1]):\n","                j = indices[idx]\n","                if j == i:\n","                    diag[i] = data[idx]\n","                    break\n","        if np.any(diag == 0):\n","            raise ValueError(\"Matrix has zero on diagonal (CSR) — GS will fail.\")\n","        # iterate\n","        for it in range(1, max_iter+1):\n","            for i in range(n):\n","                row_start = indptr[i]; row_end = indptr[i+1]\n","                s = 0.0\n","                aii = 0.0\n","                for idx in range(row_start, row_end):\n","                    j = indices[idx]\n","                    aij = data[idx]\n","                    if j == i:\n","                        aii = aij\n","                    else:\n","                        s += aij * x[j]\n","                # update\n","                x[i] = (b[i] - s) / aii\n","            # compute residual\n","            r = A.dot(x) - b\n","            res = np.linalg.norm(r)\n","            residuals.append(res)\n","            if verbose and it % 100 == 0:\n","                print(f\"it {it}, res = {res:.3e}\")\n","            if res <= tol:\n","                break\n","    else:\n","        # dense numpy array\n","        A_mat = np.asarray(A, dtype=float)\n","        diag = np.diag(A_mat)\n","        if np.any(diag == 0):\n","            raise ValueError(\"Matrix has zero on diagonal (dense) — GS will fail.\")\n","        for it in range(1, max_iter+1):\n","            for i in range(n):\n","                # compute s = sum_{j != i} a_ij * x_j\n","                s = A_mat[i, :i].dot(x[:i]) + A_mat[i, i+1:].dot(x[i+1:])\n","                x[i] = (b[i] - s) / A_mat[i, i]\n","            r = A_mat.dot(x) - b\n","            res = np.linalg.norm(r)\n","            residuals.append(res)\n","            if verbose and it % 100 == 0:\n","                print(f\"it {it}, res = {res:.3e}\")\n","            if res <= tol:\n","                break\n","\n","    time_elapsed = time.time() - start_time\n","    return x, residuals, len(residuals), time_elapsed\n"],"metadata":{"id":"qT8OE2lbngpg","executionInfo":{"status":"ok","timestamp":1764302484515,"user_tz":-420,"elapsed":8,"user":{"displayName":"Alif Putra Roy","userId":"17840951808929307884"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["def load_problem(size):\n","    \"\"\"Return A (csr or dense), b, x_true (if exists) for given size.\"\"\"\n","    if size in (50, 100):\n","        npz = np.load(f\"A_dense_{size}x{size}.npz\")\n","        A = npz[\"A\"]\n","        b = npz[\"b\"]\n","        x_true = npz[\"x_true\"]\n","        # also create sparse CSR version if you want sparse GS (we'll use dense GS for dense files)\n","        A_csr = sp.csr_matrix(A)\n","        return A, A_csr, b, x_true\n","    elif size in (500, 1000):\n","        A_csr = mmread(f\"A_sparse_{size}x{size}.mtx\").tocsr()\n","        npz = np.load(f\"b_xtrue_{size}.npz\")\n","        b = npz[\"b\"]\n","        x_true = npz[\"x_true\"]\n","        return None, A_csr, b, x_true\n","    else:\n","        raise ValueError(\"Size not supported\")\n"],"metadata":{"id":"7A0aWD6-njQ1","executionInfo":{"status":"ok","timestamp":1764302490677,"user_tz":-420,"elapsed":46,"user":{"displayName":"Alif Putra Roy","userId":"17840951808929307884"}}},"execution_count":4,"outputs":[]},{"cell_type":"code","source":["sizes = [50, 100, 500, 1000]\n","\n","results = {}  # size -> dict with info\n","\n","# parameters (you can tweak)\n","tol = 1e-8\n","max_iter_small = 5000\n","max_iter_large = 2000  # for 500/1000 keep smaller to avoid long runs\n","\n","for n in sizes:\n","    print(f\"\\n=== Running GS for n = {n} ===\")\n","    A_dense, A_csr, b, x_true = load_problem(n)\n","    if n <= 100:\n","        # run GS on dense version (typical)\n","        print(\"-> Using dense GS\")\n","        x0 = np.zeros(n)\n","        x_gs, res_hist, iters, t_elapsed = gauss_seidel(A_dense, b, x0=x0, tol=tol, max_iter=max_iter_small)\n","        rel_err = np.linalg.norm(x_gs - x_true) / np.linalg.norm(x_true)\n","        results[n] = {\n","            \"type\": \"dense\",\n","            \"residuals\": res_hist,\n","            \"iters\": iters,\n","            \"time\": t_elapsed,\n","            \"rel_err\": rel_err\n","        }\n","        print(f\"Done dense: iters={iters}, time={t_elapsed:.3f}s, rel_err={rel_err:.3e}\")\n","        # also try sparse GS on CSR (compare)\n","        print(\"-> Also running sparse CSR GS (same A converted to CSR)\")\n","        x0 = np.zeros(n)\n","        x_gs_s, res_hist_s, iters_s, t_elapsed_s = gauss_seidel(A_csr, b, x0=x0, tol=tol, max_iter=max_iter_small)\n","        rel_err_s = np.linalg.norm(x_gs_s - x_true) / np.linalg.norm(x_true)\n","        results[f\"{n}_sparse\"] = { # Fix applied here: changed n+\"_sparse\" to f\"{n}_sparse\"\n","            \"type\": \"sparse\",\n","            \"residuals\": res_hist_s,\n","            \"iters\": iters_s,\n","            \"time\": t_elapsed_s,\n","            \"rel_err\": rel_err_s\n","        }\n","        print(f\"Done sparse: iters={iters_s}, time={t_elapsed_s:.3f}s, rel_err={rel_err_s:.3e}\")\n","\n","    else:\n","        # for large, use sparse CSR GS\n","        print(\"-> Using sparse CSR GS\")\n","        x0 = np.zeros(n)\n","        x_gs, res_hist, iters, t_elapsed = gauss_seidel(A_csr, b, x0=x0, tol=tol, max_iter=max_iter_large)\n","        rel_err = np.linalg.norm(x_gs - x_true) / np.linalg.norm(x_true)\n","        results[n] = {\n","            \"type\": \"sparse\",\n","            \"residuals\": res_hist,\n","            \"iters\": iters,\n","            \"time\": t_elapsed,\n","            \"rel_err\": rel_err\n","        }\n","        print(f\"Done sparse: iters={iters}, time={t_elapsed:.3f}s, rel_err={rel_err:.3e}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"DlMD-0YcnmA7","executionInfo":{"status":"ok","timestamp":1764302573769,"user_tz":-420,"elapsed":52458,"user":{"displayName":"Alif Putra Roy","userId":"17840951808929307884"}},"outputId":"6aae5287-ce26-4bd4-8850-3ba80ec95157"},"execution_count":6,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","=== Running GS for n = 50 ===\n","-> Using dense GS\n","Done dense: iters=5000, time=2.219s, rel_err=1.144e-01\n","-> Also running sparse CSR GS (same A converted to CSR)\n","Done sparse: iters=5000, time=8.728s, rel_err=1.144e-01\n","\n","=== Running GS for n = 100 ===\n","-> Using dense GS\n","Done dense: iters=5000, time=1.769s, rel_err=1.043e-01\n","-> Also running sparse CSR GS (same A converted to CSR)\n","Done sparse: iters=5000, time=33.996s, rel_err=1.043e-01\n","\n","=== Running GS for n = 500 ===\n","-> Using sparse CSR GS\n","Done sparse: iters=2000, time=1.904s, rel_err=5.572e-02\n","\n","=== Running GS for n = 1000 ===\n","-> Using sparse CSR GS\n","Done sparse: iters=2000, time=3.685s, rel_err=6.458e-02\n"]}]},{"cell_type":"code","source":["plt.figure(figsize=(10,6))\n","\n","# plot for each run in results\n","for key, info in results.items():\n","    res = np.array(info[\"residuals\"])\n","    if res.size == 0:\n","        continue\n","    label = f\"{key} (iters={info['iters']}, err={info['rel_err']:.1e})\"\n","    plt.plot(np.arange(1, len(res)+1), res, marker='o', markersize=3, label=label)\n","\n","plt.yscale('log')\n","plt.xlabel(\"Iterasi\")\n","plt.ylabel(\"Residual ||Ax_k - b||_2 (log scale)\")\n","plt.title(\"Gauss–Seidel Convergence Curve\")\n","plt.grid(True, which='both', ls='--')\n","plt.legend()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":564},"id":"-vMMBw6Inqac","executionInfo":{"status":"ok","timestamp":1764302574668,"user_tz":-420,"elapsed":900,"user":{"displayName":"Alif Putra Roy","userId":"17840951808929307884"}},"outputId":"2bee3bd4-af37-4557-df37-5c71b0b18fa6"},"execution_count":7,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# print summary\n","print(\"Summary results:\")\n","for key, info in results.items():\n","    print(f\"- {key}: type={info['type']}, iters={info['iters']}, time={info['time']:.3f}s, rel_err={info['rel_err']:.3e}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7EM6czOHnrbe","executionInfo":{"status":"ok","timestamp":1764302581483,"user_tz":-420,"elapsed":5,"user":{"displayName":"Alif Putra Roy","userId":"17840951808929307884"}},"outputId":"c369dd57-ce8a-42f8-eabd-36709a97c658"},"execution_count":8,"outputs":[{"output_type":"stream","name":"stdout","text":["Summary results:\n","- 50: type=dense, iters=5000, time=2.219s, rel_err=1.144e-01\n","- 50_sparse: type=sparse, iters=5000, time=8.728s, rel_err=1.144e-01\n","- 100: type=dense, iters=5000, time=1.769s, rel_err=1.043e-01\n","- 100_sparse: type=sparse, iters=5000, time=33.996s, rel_err=1.043e-01\n","- 500: type=sparse, iters=2000, time=1.904s, rel_err=5.572e-02\n","- 1000: type=sparse, iters=2000, time=3.685s, rel_err=6.458e-02\n"]}]}]}